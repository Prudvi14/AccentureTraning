@model List<Movie>

<h2>Movie List</h2>

<a asp-action="Create">+ Add New Movie</a>

<table border="1">
    <tr>
        <th>Title</th>
        <th>Director</th>
        <th>Year</th>
        <th>Rating</th>
        <th>Actions</th>
    </tr>
    @foreach (var movie in Model)
    {
        <tr>
            <td>@movie.Title</td>
            <td>@movie.Director</td>
            <td>@movie.ReleaseYear</td>
            <td>@movie.Rating</td>
            <td>
                <a asp-action="Edit" asp-route-id="@movie.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@movie.Id">Delete</a>
            </td>
        </tr>
    }
</table>